JoinAssetWithDefaultSite derive(AssetStatusCode = case(isActive, 'ACTIVE', 'INACTIVE'),
		InspectionFrequency = toInteger(InspectionThreshHold),
		NewTyreAssetId = uuid(),
		HardcodedFirstFitmentDate = currentDate(),
		Position = toInteger(PositionNumber),
		FitmentId = case(
    FitmentClassificationId == 1, 'front',
    FitmentClassificationId == 2, 'rear',
    toString(null())
),
		CreatedBy = iif(isNull(AssetCreaterNewUserId), DefaultNewUserId, AssetCreaterNewUserId),
		SiteId = iif(isNull(newSiteId), DefaultnewSiteId, newSiteId),
		AssetOriginalTreadDepth = iif(
    isNull(OriginalThreadDepth), 
    iif(isNull(SpecificationOriginalTreadDepth), 0.0, toFloat(SpecificationOriginalTreadDepth)), 
    toFloat(OriginalThreadDepth)
),
		TyreSpecificationId = iif(    isNull(selectSpecificationNameAndId@Id),     'A06DC628-8A2F-493B-A5EE-041A30B3943E',     selectSpecificationNameAndId@Id),
		NewDispositionId = iif(    isNull(CompanyPropertyOptionId),  DefaultDispositionCompanyPropertyOptionId  ,     CompanyPropertyOptionId),
		AvailableTreadDepth = iif(    isNull(AvailableTreadDepth),  0.0  ,     toFloat(AvailableTreadDepth)),
		CreatedOnUtc = V2TyreAssetSource@CreationDate,
		TotalHours = HourReadingCurrent) ~> derivedColumn1

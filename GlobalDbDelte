    DELETE FROM VehicleSpecifications WHERE companyId = @CompanyId;

    DELETE FROM tenants WHERE id IN (SELECT tenantid FROM Companys WHERE id = @CompanyId);

    DELETE FROM Companys WHERE id = @CompanyId;

    -- Decide whether to commit or rollback based on parameter
    IF @CommitTransaction = 1
    BEGIN
        -- Only commit if transaction is active
        IF XACT_STATE() = 1
            COMMIT TRANSACTION;
        ELSE
            THROW 50001, 'Transaction is not in a committable state.', 1;
    END
    ELSE
    BEGIN
        IF XACT_STATE() <> 0
            ROLLBACK TRANSACTION;
        -- If rollback requested, we can return a specific code/message if desired
    END

    -- Return a simple status
    IF @CommitTransaction = 1
        SELECT 1 AS CompletedWithCommit;
    ELSE
        SELECT 0 AS RolledBackByParameter;

END TRY
BEGIN CATCH
    -- If an error occurs, ensure transaction is rolled back and rethrow the error
    IF XACT_STATE() <> 0
        ROLLBACK TRANSACTION;

    DECLARE @ErrMsg NVARCHAR(4000) = ERROR_MESSAGE();
    DECLARE @ErrSev INT = ERROR_SEVERITY();
    DECLARE @ErrState INT = ERROR_STATE();

    -- Rethrow original error
    THROW;
END CATCH
